</head>

<body>

  <div class="container">

    <!-- HERO -->
    <h1>Dein Name</h1>
    <h2>Film Editor · Narrative · Documentary</h2>

    <!-- SHOWREEL -->
    <div class="section">
      <h3><span class="accent">Showreel</span></h3>

      <div class="reel">
        <!-- HIER später dein Vimeo-Link einfügen -->
        <iframe src="https://player.vimeo.com/video/000000000" allowfullscreen></iframe>
      </div>
    </div>

    <!-- WORK -->
    <div class="section">
      <h3>Selected Work</h3>

      <div class="work-item">Projekt 1 – Kurzbeschreibung</div>
      <div class="work-item">Projekt 2 – Kurzbeschreibung</div>
      <div class="work-item">Projekt 3 – Kurzbeschreibung</div>
    </div>

