<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Nils Dueren – Film Editor</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #ffffff;
      color: #111111;
      line-height: 1.6;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 80px 24px;
    }

    h1 {
      font-size: 48px;
      margin-bottom: 8px;
      letter-spacing: -1px;
    }

    h2 {
      font-size: 18px;
      font-weight: normal;
      color: #666;
      margin-top: 0;
    }

    .accent {
      color: #FFD400;
    }

    .section {
      margin-top: 80px;
    }

    .reel {
      margin-top: 40px;
      border: 2px solid #FFD400;
      padding: 8px;
    }

    iframe {
      width: 100%;
      height: 480px;
      border: none;
    }

    .work-item {
      padding: 16px 0;
      border-bottom: 1px solid #eee;
    }

    a {
      color: #111;
      text-decoration: none;
    }

    a:hover {
      color: #FFD400;
    }
